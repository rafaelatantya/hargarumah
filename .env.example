# HargaRumah — Environment Configuration
# Copy this file to .env and fill in values as needed.

# ===== Default Search Parameters =====
# Default latitude/longitude (Bekasi Selatan)
DEFAULT_LATITUDE=-6.2607
DEFAULT_LONGITUDE=106.9894
DEFAULT_RADIUS_KM=5

# ===== Browser Settings =====
# Set to "true" to run browser in headless mode
HEADLESS=false
# Path to Chrome/Chromium binary (leave empty for auto-detect)
CHROME_PATH=

# ===== Proxy Settings (Optional) =====
# Set to "true" to enable free proxy rotation
USE_FREE_PROXY=false
# Manual proxy URL (overrides free proxy if set)
# Format: http://user:pass@host:port or socks5://host:port
PROXY_URL=

# ===== Rate Limiting =====
# Minimum delay between requests in seconds
MIN_DELAY_SECONDS=2
# Maximum delay between requests in seconds
MAX_DELAY_SECONDS=5

# ===== Logging =====
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
